# Go build artifacts
/server
*.exe

# Go module checksum (not needed in repo, always regenerated)
# go.sum  ← kept in repo so Docker builds can resolve deps

# Go test coverage
*.coverprofile

# SQLite runtime data (per-instance, never commit)
backend/data/
*.db
*.db-shm
*.db-wal

# Node.js
frontend/dist
frontend/node_modules
.vite
*.log
.DS_Store

# Build artifacts
src/__tests__/*.tsbuildinfo
vite.config.d.ts
vite.config.js
tsconfig.app.tsbuildinfo

# Prevent compiled JS artifacts in src (Vite outputs to dist/, not src/)
src/**/*.js
src/*.js
!src/index.css
!src/setupTests.*
